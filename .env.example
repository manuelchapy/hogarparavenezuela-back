# Servidor
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hogarparavenezuela

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=8h

# Almacenamiento (elegir proveedor: local | s3 | gcs)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
PUBLIC_BASE_URL=http://localhost:4000

# Imágenes — conversión automática a WebP antes de subir (JPEG/PNG/WebP)
IMAGE_WEBP_QUALITY=82

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hogarparavenezuela-media

# Google Cloud Storage
GCS_PROJECT_ID=hogarparavenezuela
GCS_BUCKET=hogarparavenezuela-media
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcs-service-account.json

# Webhooks n8n
N8N_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/alertas-nna
N8N_WEBHOOK_SECRET=

# CORS (origen del front / PWA)
CORS_ORIGIN=http://localhost:3000

# Bootstrap — primer administrador (solo si no existe admin activo)
BOOTSTRAP_SECRET=cambia-este-secreto-bootstrap
