{
  "name": "hogarparavenezuela-back",
  "version": "1.0.0",
  "description": "Backend — Plataforma de Rescate y Trazabilidad de NNA (Sismo Central)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:geo": "node scripts/seed-venezuela-geo.js",
    "seed:geo:drop": "node scripts/seed-venezuela-geo.js --drop",
    "seed:institutions": "node scripts/seed-institutions.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "nna",
    "emergencia",
    "express",
    "mongodb"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@google-cloud/storage": "^7.15.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "zod": "^3.24.2"
  }
}
